# =============================================================================
# Paragliding Airflow Planning System — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://paraglide:paraglide@localhost:5432/paraglide_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Weather Provider ---
# Options: mock, open_meteo
WEATHER_PROVIDER=mock

# Open-Meteo (used when WEATHER_PROVIDER=open_meteo)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# --- Cloud Observation Provider ---
# Options: mock
CLOUD_PROVIDER=mock

# --- Site ---
# The site slug to load from config/site_profiles/{SITE_ID}.json
SITE_ID=eagle_ridge

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
